# Analytics provider IDs. Both are optional; leaving either blank disables
# only that provider. These are read at *build time* by Vite (`VITE_` prefix
# is mandatory for client-side exposure). In CI they are injected from
# GitHub Actions Secrets — see docs/ANALYTICS.md.

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_ID=

# Microsoft Clarity project ID (~10 alphanumeric chars)
VITE_CLARITY_ID=
